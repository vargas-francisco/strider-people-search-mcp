{
  "name": "strider-people-search-mcp",
  "version": "0.1.0",
  "description": "Unofficial MCP server for Strider's people-search API",
  "type": "module",
  "main": "dist/entrypoints/stdio.js",
  "bin": {
    "strider-people-search-mcp": "dist/entrypoints/stdio.js",
    "strider-people-search-mcp-http": "dist/entrypoints/http.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/resources dist/resources",
    "dev:stdio": "tsx src/entrypoints/stdio.ts",
    "dev:http": "tsx src/entrypoints/http.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "vitest run --config vitest.eval.config.ts --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "types": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.14.6",
    "openai": "^6.39.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
